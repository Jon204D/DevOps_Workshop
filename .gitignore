# Environment — real values never committed; .env.example files are safe
.env
.env.local
.env.*.local
*.env.local
frontend/.env.local
frontend/.env.production.local

# Outputs — contain credentials, never commit
outputs/
!outputs/.gitkeep

# Terraform — state holds account IDs, ARNs, and plaintext sensitive outputs (login_profile.password, etc.)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# Lock files SHOULD be committed (pin provider versions) — don't ignore .terraform.lock.hcl.

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
# Vendored / bundled dependencies (pip install --target or Lambda layers)
_build/
package/
lambda_package/
*.zip

# Node / frontend
node_modules/
.next/
.nuxt/
coverage/
*.log
npm-debug.log*
yarn-error.log*

# Key pairs and private keys — never commit
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# CSV files — may contain PII, student rosters, credentials, or raw data
# Commit only explicit exceptions with !path/to/file.csv
*.csv

# Legacy script secrets (preserved from original quick-labs)
api_token.py
ConnectionDetails.txt
examples/digitalocean/YT_intro.py

# macOS
.DS_Store

# Editor / tooling
.idea/
.vscode/

# Claude Code — share skills/agents/commands; keep per-user settings local
.claude/settings.local.json
.claude/.cache/
.claude/projects/
.claude/sessions/
